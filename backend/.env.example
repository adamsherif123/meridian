# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL → Supabase dashboard → Settings → API → Project URL
SUPABASE_URL=https://your-project.supabase.co

# Service-role key (server-side only — never expose to the browser)
# Supabase dashboard → Settings → API → service_role secret
SUPABASE_SERVICE_KEY=eyJ...

# ── Composio ──────────────────────────────────────────────────────────────────
# API key → https://app.composio.dev → Settings → API Keys
COMPOSIO_API_KEY=your-composio-api-key

# ── Temporal ──────────────────────────────────────────────────────────────────
# Default is fine for local `temporal server start-dev`
TEMPORAL_ADDRESS=localhost:7233
